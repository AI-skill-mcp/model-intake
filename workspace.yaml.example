# model-intake 工作区配置（示例）

version: "1.0"

workspace:
  root: /path/to/your/kbase-data

  # 原始数据相对目录（默认 rawdata；foundation-models 等 monorepo 设为 bioinformatics）
  rawdata_dir: rawdata

  graph_database_dir: Graph_Database
  with_graph: true
  name: kbase-data
  mode: standalone

  created_at: "2026-07-03"
  updated_at: "2026-07-03"

graph_sync:
  preference: ask
  preference_set_at: "2026-07-03"

# embedded 示例:
# workspace:
#   root: /path/to/foundation-models
#   rawdata_dir: bioinformatics
#   mode: embedded
